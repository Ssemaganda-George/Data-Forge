"use client";

import { useState } from "react";
import {
  IconDatabase,
  IconChevronDown,
  IconDownload,
  IconSparkles,
  IconClipboardList,
  IconEye,
  IconAlertTriangle,
  IconFlag,
} from "@tabler/icons/react";
import { formatBytes } from "@/lib/utils";
import { CleanedOutputView } from "@/components/cleaned-result-detail";
import { ExportActions } from "@/components/export-actions";
import type { ExportFormat } from "@/lib/export-builder";
import type { DatasetAnalysis } from "@/lib/dataset-ai";
import type { DataCard } from "@/lib/data-card";

export interface DatasetFileView {
  id: string;
  originalName: string;
  fileType: string;
  sizeBytes: number | null;
  confidenceScore: number | null;
  flaggedForReview: boolean;
  cleanedContent: string;
  cleaningActions: { type: string; description: string }[];
}

export interface DatasetViewModel {
  id: string;
  name: string;
  project: string;
  format: string;
  fileCount: number;
  sizeBytes: number;
  createdAt: string;
  batchId: string;
  files: DatasetFileView[];
  datacard: DataCard;
  analysis: DatasetAnalysis;
}

type Tab = "preview" | "ai" | "card";

const FORMATS: ExportFormat[] = ["CSV", "JSON", "PARQUET", "COCO"];

export function DatasetsList({ datasets }: { datasets: DatasetViewModel[] }) {
  const [openId, setOpenId] = useState<string | null>(null);

  if (datasets.length === 0) {
    return (
      <div className="space-y-6">
        <h1 className="text-xl font-semibold text-gray-900">Datasets</h1>
        <div className="bg-white border border-gray-100 rounded-xl px-4 py-12 text-center">
          <p className="text-sm text-gray-500">
            No datasets yet. Export a project batch to see it here.
          </p>
        </div>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <div className="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
        <div>
          <h1 className="text-xl font-semibold text-gray-900">Datasets</h1>
          <p className="mt-0.5 text-sm text-gray-500">
            Saved, model-ready exports. Open one to preview, review the AI
            analysis and data card, then download or publish it.
          </p>
        </div>
        <span className="text-xs text-gray-400">
          {datasets.length} dataset{datasets.length === 1 ? "" : "s"}
        </span>
      </div>

      <div className="space-y-3">
        {datasets.map((d) => (
          <DatasetCard
            key={d.id}
            dataset={d}
            expanded={openId === d.id}
            onToggle={() =>
              setOpenId((cur) => (cur === d.id ? null : d.id))
            }
          />
        ))}
      </div>
    </div>
  );
}

function DatasetCard({
  dataset,
  expanded,
  onToggle,
}: {
  dataset: DatasetViewModel;
  expanded: boolean;
  onToggle: () => void;
}) {
  const [tab, setTab] = useState<Tab>("preview");
  const [format, setFormat] = useState<ExportFormat>("JSON");

  const flagged = dataset.files.filter((f) => f.flaggedForReview).length;

  return (
    <div className="bg-white border border-gray-100 rounded-xl overflow-hidden">
      <button
        type="button"
        onClick={onToggle}
        className="w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-gray-50 transition-colors"
      >
        <IconDatabase size={18} className="text-gray-400 shrink-0" stroke={1.5} />
        <div className="min-w-0 flex-1">
          <p className="text-sm font-medium text-gray-900 truncate">
            {dataset.name}
          </p>
          <p className="text-xs text-gray-400 truncate">
            {dataset.project} · {dataset.fileCount} files ·{" "}
            {formatBytes(dataset.sizeBytes)} · {dataset.createdAt}
          </p>
        </div>
        <ExportActions
          batchId={dataset.batchId}
          format={format}
          disabled={expanded ? false : false}
          className="shrink-0"
        />
        <IconChevronDown
          size={16}
          className={`text-gray-400 shrink-0 transition-transform ${
            expanded ? "rotate-180" : ""
          }`}
        />
      </button>

      {expanded && (
        <div className="border-t border-gray-100 px-4 py-4">
          <div className="flex flex-wrap items-center gap-3 mb-4">
            <span className="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono bg-gray-100 text-gray-700">
              {dataset.format}
            </span>
            <FormatToggle format={format} onChange={setFormat} />
            {flagged > 0 && (
              <span className="inline-flex items-center gap-1 text-xs text-amber-600">
                <IconFlag size={12} /> {flagged} flagged
              </span>
            )}
          </div>

          <div className="flex gap-1 border-b border-gray-100 mb-4">
            <TabButton active={tab === "preview"} onClick={() => setTab("preview")}>
              <IconEye size={14} /> Preview
            </TabButton>
            <TabButton active={tab === "ai"} onClick={() => setTab("ai")}>
              <IconSparkles size={14} /> AI analysis
            </TabButton>
            <TabButton active={tab === "card"} onClick={() => setTab("card")}>
              <IconClipboardList size={14} /> Data card
            </TabButton>
          </div>

          {tab === "preview" && <PreviewTab dataset={dataset} />}
          {tab === "ai" && <AiTab analysis={dataset.analysis} />}
          {tab === "card" && <DataCardTab datacard={dataset.datacard} batchId={dataset.batchId} />}
        </div>
      )}
    </div>
  );
}

function TabButton({
  active,
  onClick,
  children,
}: {
  active: boolean;
  onClick: () => void;
  children: React.ReactNode;
}) {
  return (
    <button
      type="button"
      onClick={onClick}
      className={`flex items-center gap-1.5 px-3 py-2 text-xs font-medium border-b-2 -mb-px transition-colors ${
        active
          ? "border-[#028090] text-[#028090]"
          : "border-transparent text-gray-500 hover:text-gray-700"
      }`}
    >
      {children}
    </button>
  );
}

function FormatToggle({
  format,
  onChange,
}: {
  format: ExportFormat;
  onChange: (f: ExportFormat) => void;
}) {
  return (
    <div className="flex items-center gap-1 text-xs">
      <span className="text-gray-400 mr-1">Download as</span>
      {FORMATS.map((f) => (
        <button
          key={f}
          type="button"
          onClick={() => onChange(f)}
          className={`px-2 py-0.5 rounded font-mono transition-colors ${
            format === f
              ? "bg-[#028090] text-white"
              : "bg-gray-100 text-gray-600 hover:bg-gray-200"
          }`}
        >
          {f}
        </button>
      ))}
    </div>
  );
}

function PreviewTab({ dataset }: { dataset: DatasetViewModel }) {
  if (dataset.files.length === 0) {
    return (
      <p className="text-sm text-gray-500">
        This dataset has no file previews.
      </p>
    );
  }

  return (
    <div className="space-y-4">
      {dataset.files.map((f, i) => (
        <div
          key={f.id}
          className="rounded-lg border border-[#E5E7EB] bg-[#F7FAF9] p-4"
        >
          <div className="flex items-center justify-between gap-2 mb-2">
            <p className="text-sm font-medium text-gray-800 truncate">
              {i + 1}. {f.originalName}
            </p>
            <div className="flex items-center gap-2 shrink-0">
              {typeof f.confidenceScore === "number" && (
                <span className="text-xs text-gray-400">
                  {Math.round(f.confidenceScore * 100)}%
                </span>
              )}
              {f.flaggedForReview && (
                <span className="inline-flex items-center gap-1 text-xs text-amber-600">
                  <IconFlag size={11} /> flagged
                </span>
              )}
            </div>
          </div>
          <CleanedOutputView
            content={f.cleanedContent}
            score={f.confidenceScore}
          />
        </div>
      ))}
    </div>
  );
}

function AiTab({ analysis }: { analysis: DatasetAnalysis }) {
  return (
    <div className="space-y-4">
      {analysis.note && (
        <div className="flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700">
          <IconAlertTriangle size={14} className="mt-0.5 shrink-0" />
          <span>{analysis.note}</span>
        </div>
      )}

      <section>
        <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
          Dataset overview
        </p>
        <p className="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">
          {analysis.overview}
        </p>
        {analysis.synthesized && (
          <span className="mt-1.5 inline-block text-[11px] text-gray-400">
            Synthesized across all files with Groq.
          </span>
        )}
      </section>

      {analysis.tags.length > 0 && (
        <section>
          <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
            Tags
          </p>
          <div className="flex flex-wrap gap-1.5">
            {analysis.tags.map((t) => (
              <span
                key={t}
                className="inline-flex px-2 py-0.5 rounded-full bg-[#E6F4F2] text-[#028090] text-xs"
              >
                {t}
              </span>
            ))}
          </div>
        </section>
      )}

      {(analysis.entities.organizations.length > 0 ||
        analysis.entities.people.length > 0 ||
        analysis.entities.locations.length > 0 ||
        analysis.entities.dates.length > 0) && (
        <section>
          <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
            Key entities
          </p>
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-xs">
            <Entity label="Organizations" items={analysis.entities.organizations} />
            <Entity label="People" items={analysis.entities.people} />
            <Entity label="Locations" items={analysis.entities.locations} />
            <Entity label="Dates" items={analysis.entities.dates} />
          </div>
        </section>
      )}

      {analysis.qaPairs.length > 0 && (
        <section>
          <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
            Question &amp; answer pairs
          </p>
          <div className="space-y-2">
            {analysis.qaPairs.map((qa, i) => (
              <div
                key={i}
                className="rounded-lg border border-[#E5E7EB] bg-white px-3 py-2"
              >
                <p className="text-xs font-medium text-gray-800">Q: {qa.question}</p>
                <p className="text-xs text-gray-600 mt-0.5">A: {qa.answer}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <section>
        <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
          Per-file reports
        </p>
        <div className="space-y-2">
          {analysis.perFile.map((f, i) => (
            <div key={i} className="text-xs">
              <p className="font-medium text-gray-700">
                {i + 1}. {f.name}
              </p>
              {f.report ? (
                <p className="text-gray-500 mt-0.5 line-clamp-3 whitespace-pre-wrap">
                  {f.report}
                </p>
              ) : (
                <p className="text-gray-400 mt-0.5">No AI report for this file.</p>
              )}
            </div>
          ))}
        </div>
      </section>
    </div>
  );
}

function Entity({ label, items }: { label: string; items: string[] }) {
  if (items.length === 0) return null;
  return (
    <div>
      <dt className="text-[11px] font-medium text-gray-400 uppercase tracking-wide">
        {label}
      </dt>
      <dd className="text-gray-700">{items.join(", ")}</dd>
    </div>
  );
}

function DataCardTab({
  datacard,
  batchId,
}: {
  datacard: DataCard;
  batchId: string;
}) {
  function downloadDatacard() {
    const blob = new Blob([JSON.stringify(datacard, null, 2)], {
      type: "application/json",
    });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `datacard-${batchId.slice(0, 8)}.json`;
    a.click();
    URL.revokeObjectURL(url);
  }

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <p className="text-xs text-gray-500">
          An auditable record of the whole dataset.
        </p>
        <button
          type="button"
          onClick={downloadDatacard}
          className="text-xs text-brand-600 hover:underline flex items-center gap-1"
        >
          <IconDownload size={12} /> JSON
        </button>
      </div>

      <section>
        <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
          Source
        </p>
        <dl className="space-y-1.5 text-xs">
          <Row label="Total files" value={datacard.sourceSummary.totalFiles.toLocaleString()} />
          <Row label="Total size" value={`${datacard.sourceSummary.totalSizeMb.toLocaleString()} MB`} />
          {Object.entries(datacard.sourceSummary.fileTypes).map(([type, count]) => (
            <Row key={type} label={type} value={String(count)} mono />
          ))}
        </dl>
      </section>

      <section>
        <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
          Cleaning actions
        </p>
        <ul className="space-y-1.5">
          {datacard.cleaningActions.map((a) => (
            <li key={a.type} className="flex items-center gap-2 text-xs">
              <IconClipboardList size={12} className="text-[#028090] shrink-0" />
              <span className="text-gray-600">{a.description}</span>
              <span className="ml-auto text-gray-400">×{a.count}</span>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <p className="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
          Quality
        </p>
        <dl className="space-y-1.5 text-xs">
          <Row
            label="Avg confidence"
            value={`${(datacard.qualityStats.avgConfidenceScore * 100).toFixed(1)}%`}
          />
          <Row label="Accepted" value={String(datacard.qualityStats.acceptedCount)} />
          <Row label="Flagged" value={String(datacard.qualityStats.flaggedCount)} />
        </dl>
      </section>
    </div>
  );
}

function Row({
  label,
  value,
  mono,
}: {
  label: string;
  value: string;
  mono?: boolean;
}) {
  return (
    <div className="flex justify-between">
      <dt className="text-gray-500">{label}</dt>
      <dd className={`font-medium text-gray-800 ${mono ? "font-mono text-gray-600" : ""}`}>
        {value}
      </dd>
    </div>
  );
}
